# Canonical site URL (no trailing slash). Used for metadata, sitemap, schema.
NEXT_PUBLIC_SITE_URL=https://www.example.com

# Defaults to "/clientwebsite" (this repo's own deployment, proxied at
# sureflowleads.com/clientwebsite). Redeploying at a plain root domain
# for a future client: set this to an empty string to clear it.
# NEXT_PUBLIC_BASE_PATH=

# Optional: where submitLead() forwards leads (see src/app/actions.ts)
# LEAD_WEBHOOK_URL=https://hooks.example.com/lead
